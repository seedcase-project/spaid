#!/bin/zsh

help_text="
Usage: `basename $0` [-h]

List all users (their 'login', not the human-readable name) within a specific
team in a GitHub organization.

Example:

    $ spaid_team_list_users seedcase-project platform-tools
    lwjohnst86

Positional arguments:

1. organization: The GitHub organization name.
2. team_slug: The GitHub organization team 'slug' name.
"

if [[ "$1" == "-h" ]] ; then
  echo $help_text
  exit 0
fi

org="$1"
team="$2"

if [[ -z "$org" ]] ; then
  echo "Error: organization name is required."
  echo $help_text
  exit 1
fi

if [[ -z "$team" ]] ; then
  echo "Error: team slug is required."
  echo $help_text
  exit 1
fi

gh api \
  -H "Accept: application/vnd.github+json" \
  -H "X-GitHub-Api-Version: 2026-03-10" \
  /orgs/$org/teams/$team/members \
  -q ".[] | .login"
