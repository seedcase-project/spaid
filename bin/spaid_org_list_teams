#!/bin/zsh

help_text="
Usage: `basename $0` [-h]

List all teams (their 'slug', not the human-readable name) within a specific
organization.

Example:

    $ spaid_org_list_teams seedcase-project
    admin
    developers

Positional arguments:

1. organization: The GitHub organization name.
"

if [[ "$1" == "-h" ]] ; then
  echo $help_text
  exit 0
fi

org="$1"

if [[ -z "$org" ]] ; then
  echo "Error: organization name is required."
  echo $help_text
  exit 1
fi

gh api \
  -H "Accept: application/vnd.github+json" \
  -H "X-GitHub-Api-Version: 2022-11-28" \
  /orgs/$org/teams \
  -q ".[] | .slug"
